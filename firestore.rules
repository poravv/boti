rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Tenants: solo el super-admin o el propio org puede leer su doc
    match /tenants/{orgId} {
      allow read: if request.auth != null && (request.auth.token.superadmin == true || request.auth.uid == resource.data.ownerUid);
      allow write: if request.auth != null && request.auth.token.superadmin == true;
    }
    // Subscriptions: solo el super-admin gestiona, el org puede leer la suya
    match /subscriptions/{orgId} {
      allow read: if request.auth != null && (request.auth.token.superadmin == true || request.auth.uid == resource.data.ownerUid);
      allow write: if request.auth != null && request.auth.token.superadmin == true;
    }
  }
}