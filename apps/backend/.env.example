# Boti Backend Environment Variables
NODE_ENV=development
PORT=3001

# PostgreSQL
DATABASE_URL="postgresql://boti_user:boti_password@localhost:5432/boti_db?schema=public"

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# AI API Keys
OPENAI_API_KEY=
GEMINI_API_KEY=
CLAUDE_API_KEY=
GROK_API_KEY=

# Default AI provider: gemini | openai | claude | grok
DEFAULT_AI_PROVIDER=gemini

# Anti-spam config (messages per minute before block)
SPAM_THRESHOLD=50
SPAM_BLOCK_DURATION_MS=86400000

# Context config
CONTEXT_MAX_MESSAGES=10

# Logs
LOG_LEVEL=info
