// Prisma DB Schema for Boti

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id          String    @id @default(uuid())
  phone       String    @unique
  name        String
  isBlocked   Boolean   @default(false)
  blockedUntil DateTime?
  aiPausedUntil DateTime?
  assignedToUserId String?
  assignedTo      User?     @relation(fields: [assignedToUserId], references: [id])
  conversationStatus  String    @default("OPEN")
  closedAt            DateTime?
  closedByUserId      String?
  closedBy            User?     @relation("ClosedConversations", fields: [closedByUserId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  messages        Message[]
  orgId           String?

  @@index([orgId])
}

model Message {
  id          String    @id @default(uuid())
  lineId      String
  clientPhone String
  content     String
  type        String    // TEXT | IMAGE | PDF | LINK
  direction   String    // INBOUND | OUTBOUND
  status      String    // PENDING | SUCCESS | FAILED
  sentAt      DateTime?
  isRead      Boolean   @default(false)
  createdAt   DateTime  @default(now())
  client      Client    @relation(fields: [clientPhone], references: [phone])
  line        WhatsAppLine @relation(fields: [lineId], references: [id])
}

model WhatsAppLine {
  id                     String    @id @default(uuid())
  name                   String
  phone                  String?
  status                 String    @default("DISCONNECTED")
  systemPrompt           String?
  assignedAiProvider     String?
  aiApiKey               String?
  aiModel                String?
  contextUrl             String?
  contextHeaders         Json?
  businessContext        Json?
  maxMessages            Int       @default(10)
  autonomousSalesEnabled Boolean   @default(false)
  createdAt              DateTime  @default(now())
  messages               Message[]
  externalApis           ExternalApi[]
  pagoParConfig          PagoParConfig?
  facturadorConfig       FacturadorConfig?
  saleRecords            SaleRecord[]
  calendarConfig         CalendarConfig?
  appointments           Appointment[]
  operators              User[]         @relation("OperatorLine")
  orgId                  String?

  @@index([orgId])
}

model PagoParConfig {
  id          String       @id @default(uuid())
  lineId      String       @unique
  line        WhatsAppLine @relation(fields: [lineId], references: [id], onDelete: Cascade)
  publicKey   String
  privateKey  String
  baseUrl     String?
  sandboxMode Boolean      @default(true)
  callbackUrl String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model FacturadorConfig {
  id             String       @id @default(uuid())
  lineId         String       @unique
  line           WhatsAppLine @relation(fields: [lineId], references: [id], onDelete: Cascade)
  baseUrl        String
  accessKey      String
  secretKey      String
  apiKey         String?
  bodyTemplate   Json
  successExample Json?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model SaleRecord {
  id             String       @id @default(uuid())
  lineId         String
  line           WhatsAppLine @relation(fields: [lineId], references: [id], onDelete: Cascade)
  clientPhone       String
  clientName        String?
  receptorDocumento String?   // RUC o CI del cliente para facturación
  receptorNombre    String?   // Nombre legal del receptor (explícitamente pedido al cliente)
  receptorEmail     String?   // Email del receptor para SIFEN
  hashPedido     String?
  pagoParOrderId String?
  paymentLinkUrl String?
  amount         Int
  currency       String       @default("PYG")
  status         String       @default("PENDING")
  items          Json
  invoiceId      String?
  paidAt         DateTime?
  invoicedAt     DateTime?
  createdAt      DateTime     @default(now())

  @@index([lineId])
  @@index([hashPedido])
  @@index([clientPhone])
}

model ConversationContext {
  id          String   @id @default(uuid())
  lineId      String
  clientPhone String
  clientName  String
  summary     String   @default("")
  messages    Json     @default("[]")
  updatedAt   DateTime @updatedAt

  @@unique([lineId, clientPhone])
}

model User {
  id           String    @id @default(uuid())
  email        String?   @unique
  username     String?   @unique
  passwordHash String?   // null for Firebase-only users
  name         String
  role         String    @default("OPERATOR") // SUPERADMIN | ADMIN | OPERATOR
  isActive     Boolean   @default(true)
  assignedClients     Client[]
  closedConversations Client[]       @relation("ClosedConversations")
  authoredNotes       InternalNote[] @relation("AuthoredNotes")
  createdAt    DateTime  @default(now())
  orgId        String?
  lineId       String?
  line         WhatsAppLine? @relation("OperatorLine", fields: [lineId], references: [id])

  @@index([orgId])
  @@index([username])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  details   Json
  ipAddress String?
  createdAt DateTime @default(now())
}

model ExternalApi {
  id          String   @id @default(uuid())
  lineId      String
  name        String
  baseUrl     String
  method      String   @default("GET")
  headers     Json     @default("{}")
  body        String?
  outputKey   String?
  username    String?
  password    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  line        WhatsAppLine @relation(fields: [lineId], references: [id], onDelete: Cascade)
}

model InternalNote {
  id          String   @id @default(uuid())
  clientPhone String
  authorId    String
  content     String
  createdAt   DateTime @default(now())

  author      User     @relation("AuthoredNotes", fields: [authorId], references: [id])

  @@index([clientPhone])
}

model CalendarConfig {
  id           String       @id @default(cuid())
  lineId       String       @unique
  line         WhatsAppLine @relation(fields: [lineId], references: [id], onDelete: Cascade)
  accessToken  String
  refreshToken String
  tokenExpiry  DateTime?
  calendarId   String       @default("primary")
  timezone     String       @default("America/Asuncion")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Appointment {
  id            String       @id @default(cuid())
  lineId        String
  line          WhatsAppLine @relation(fields: [lineId], references: [id], onDelete: Cascade)
  clientPhone   String?
  clientName    String?
  title         String
  notes         String?
  startAt       DateTime
  endAt         DateTime
  googleEventId String?
  status        String       @default("SCHEDULED") // SCHEDULED | CANCELLED | COMPLETED
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([lineId])
  @@index([startAt])
}

model Plan {
  id                       String         @id @default(uuid())
  name                     String
  slug                     String         @unique
  price                    Float          @default(0)
  maxLines                 Int            @default(1)      // -1 = unlimited
  maxUsers                 Int            @default(2)      // -1 = unlimited
  maxConversationsPerMonth Int            @default(200)    // -1 = unlimited
  trialDays                Int            @default(0)
  aiEnabled                Boolean        @default(true)
  isActive                 Boolean        @default(true)
  organizations            Organization[]
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt
}

model Organization {
  id                      String    @id @default(uuid())
  name                    String
  slug                    String    @unique
  description             String?
  planId                  String?
  plan                    Plan?     @relation(fields: [planId], references: [id])
  planStartedAt           DateTime?
  trialEndsAt             DateTime?
  isActive                Boolean   @default(true)
  conversationsThisMonth  Int       @default(0)
  usageResetAt            DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
}

model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
